# Supabase credentials (required for production)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Dev-only: password for local development (bypasses Supabase)
VITE_DEV_PASSWORD=acm2026

# ── Google Integration (optional) ──────────────────────────────
# These are stored as Supabase secrets for the Edge Functions,
# NOT as frontend env vars. Listed here for documentation only.
#
# Run `node scripts/google-auth.mjs` to get your refresh token,
# then set these via `supabase secrets set`:
#
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret
# GOOGLE_REFRESH_TOKEN=your-refresh-token
#
# ── Drive folder structure ─────────────────────────────────────
# Run `node scripts/scaffold-drive.mjs` to create this structure
# automatically, or set these manually with your existing folder IDs:
#
# GOOGLE_ROOT_FOLDER_ID=top-level-folder-id
# GOOGLE_BOARD_FOLDER_ID=board-meetings-folder-id
# GOOGLE_BOARD_AGENDA_TEMPLATE_ID=board-agenda-template-doc-id
# GOOGLE_BOARD_MINUTES_TEMPLATE_ID=board-minutes-template-doc-id
# GOOGLE_COMMITTEE_FOLDER_ID=committee-meetings-folder-id
# GOOGLE_COMMITTEE_AGENDA_TEMPLATE_ID=committee-agenda-template-doc-id
# GOOGLE_COMMITTEE_MINUTES_TEMPLATE_ID=committee-minutes-template-doc-id
# GOOGLE_COMMITTEE_FOLDER_MAP={"Executive":"id","Finance":"id","Governance":"id","Development":"id"}
# GOOGLE_GENERIC_AGENDA_TEMPLATE_ID=generic-agenda-template-doc-id
# GOOGLE_GENERIC_MINUTES_TEMPLATE_ID=generic-minutes-template-doc-id
#
# ── Calendar ───────────────────────────────────────────────────
# GOOGLE_CALENDAR_ID=primary
